SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@example.com
